<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      OriathHub.Sdk ships in SDK/. Commit OriathHub.Sdk.<version>.nupkg there so
      anyone who clones this repo (or the Plugins Marketplace) can build without setup.
      nuget.org is re-added after clear so other PackageReferences still resolve.
    -->
    <add key="oriathhub-sdk" value="SDK" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
